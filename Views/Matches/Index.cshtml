@model List<MiniDatingApp.Models.Match>
@{
    ViewData["Title"] = "Matches";
    int currentId = (int)ViewBag.CurrentProfileId;
}

<h3>Matches</h3>

@if (!Model.Any())
{
    <div class="alert alert-info">No matches have been played yet.</div>
}
else
{
    <div class="list-group">
        @foreach (var m in Model)
        {
            <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
               asp-action="Details" asp-route-id="@m.Id">
                <div>
                    <div><strong>It’s a Match</strong> (MatchId: @m.Id)</div>
                    <div class="small text-muted">Created: @m.CreatedAt.ToLocalTime()</div>
                </div>
                @if (m.Suggestion != null)
                {
                    <span class="badge bg-success">
                        Date: @m.Suggestion.StartTime.ToLocalTime().ToString("dd/MM HH:mm")
                    </span>
                }
                else
                {
                    <span class="badge bg-secondary">no have schedule </span>
                }
            </a>
        }
    </div>
}