<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"] - MiniDatingApp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" asp-controller="Profiles" asp-action="Index">MiniDatingApp</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-controller="Profiles" asp-action="Index">Profiles</a>
                <a class="nav-link" asp-controller="Profiles" asp-action="Create">Create</a>
                <a class="nav-link" asp-controller="Matches" asp-action="Index">Matches</a>
            </div>
        </div>
    </nav>

    <div class="container py-4">
        @if (TempData["Toast"] != null)
        {
            <div class="alert alert-info">@TempData["Toast"]</div>
        }
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>